title: Maestro UI Test Plan
summary: A comprehensive plan showcasing every module type for UI testing and visual regression. Covers all statuses, severities, data states, and edge cases.

modules[8]:
  - type: criteria
    heading: Acceptance Criteria
    items[5]:
      - text: All module types render with correct typography and spacing
      - text: Dark mode smoothly transitions every component
        answered: true
      - text: Empty states and edge cases display gracefully
      - text: Animations play sequentially without jarring
      - text: Responsive layout works down to 320px viewport width
        answered: true

  - type: steps
    heading: Implementation Steps
    items[7]:
      - text: Audit existing CSS for hardcoded color values
        owner: ui-team
        status: done
      - text: Define design tokens and CSS custom properties
        owner: ui-team
        status: done
      - text: Implement dark mode color palette
        owner: ui-team
        status: in-progress
      - text: Add glass-morphism header with backdrop-filter
        owner: ui-team
        status: in-progress
      - text: Build card hover animations and transitions
        owner: ui-team
        status: pending
      - text: Test all component states across browsers
        owner: qa-team
        status: pending
      - text: Sign off on final visual QA
        owner: product
        status: blocked

  - type: risks
    heading: Risks & Mitigations
    items[4]:
      - text: Dark mode color contrast may not meet WCAG AA standards
        severity: high
        impact: Users with visual impairments cannot use the app comfortably
        mitigation: Run automated contrast checks and adjust tokens before merging
      - text: Backdrop-filter performance on low-end hardware
        severity: medium
        impact: Janky scrolling and reduced frame rate on older devices
        mitigation: Add a @supports check and fallback solid background
      - text: CSS animation conflicts with browser preference for reduced motion
        severity: medium
        impact: Users with motion sensitivity experience discomfort
        mitigation: Wrap animations in prefers-reduced-motion media query
      - text: Template variable name mismatch in one component
        severity: low
        impact: Single module type fails to render
        mitigation: All component templates are tested individually

  - type: assumptions
    heading: Assumptions
    items[4]:
      - text: All users run modern browsers that support CSS custom properties
      - text: The Go html/template rendering layer does not require JS for layout
      - text: Plans will never exceed 50 modules per plan document
      - text: Dark mode preference is detected via system-level media query only

  - type: changes
    heading: Files Changed
    items[6]:
      - text: maestro/static/style.css
        type: refactor
      - text: maestro/templates/plans.html
        type: template
      - text: maestro/templates/base.html
        type: template
      - text: maestro/templates/plan.html
        type: template
      - text: maestro/plans/demo.toon
        type: docs
      - text: maestro/plans/test-all-modules.toon
        type: test

  - type: notes
    heading: Implementation Notes
    items[3]:
      - text: The CSS rewrite replaces all hardcoded colors with token references. No visual regression is expected for existing plan files.
      - text: To verify dark mode, toggle your OS appearance setting. The UI responds instantly with no page reload.
      - text: Animation delays are staggered by module index (60ms per module). With 8 modules total, the last one animates in ~420ms after the first.

  - type: questions
    heading: Open Questions
    items[4]:
      - text: Should we add a manual dark/light mode toggle in the header?
        answered: true
        answer: Not yet — system preference detection covers 95% of use cases.
      - text: Do we need to support Internet Explorer 11?
        answered: true
        answer: No — the project targets modern browsers only (Go 1.26+ ecosystem).
      - text: Should module cards use an accordion pattern for long plans?
        answered: false
      - text: What is the target contrast ratio for badge text colors?
        answered: true
        answer: Minimum 4.5:1 for normal text, 3:1 for large text per WCAG AA.